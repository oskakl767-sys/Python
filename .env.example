# ============================================
# Telegram Bot
# ============================================
BOT_TOKEN=your_bot_token_here

# IDs المديرين المصرح لهم (مفصولة بفواصل)
ADMIN_IDS=123456789,987654321

# ============================================
# Security Keys (مطلوبان)
# ============================================
# مفتاح E2E للتشفير - اشتقاق مفاتيح AES-256
E2E_KEY=change_this_to_a_random_64_char_hex_string

# مفتاح حماية صفحات الويب و API
LIVE_ACCESS_KEY=change_this_to_another_random_string

# ============================================
# Server
# ============================================
PORT=5000
MDM_SECRET_KEY=change_this_secret

# ============================================
# إبقاء السيرفر مستيقظ (منع نوم Render)
# ============================================
# رابط السيرفر نفسه - سيزور نفسه كل 4 دقائق
SERVER_URL=https://b-lpf3.onrender.com

# ============================================
# Database
# ============================================
MDM_DATABASE_URL=sqlite:///mdm_devices.db